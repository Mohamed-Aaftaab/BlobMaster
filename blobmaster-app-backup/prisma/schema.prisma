generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "sqlite"
  url       = "file:./dev.db"
}

model Autopilot {
  id                  String   @id @default(cuid())
  blobId              String   @unique
  renewWhenEpochsLeft Int      @default(100000)
  maxPriceUsdc        Float    @default(1.00)
  webhookUrl          String?
  active              Boolean  @default(true)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  renewals RenewalHistory[]
}

model RenewalHistory {
  id              String    @id @default(cuid())
  blobId          String
  txHash          String
  walrusJobId     String
  receiptCid      String?
  epochAtRenewal  Int
  createdAt       DateTime  @default(now())

  autopilot Autopilot @relation(fields: [blobId], references: [blobId])
}
