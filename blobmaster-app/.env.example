# ── SUI & Walrus ─────────────────────────────────────────────────────────────
SUI_RPC_URL=https://sui-testnet.gateway.tatum.io
BLOBMASTER_REGISTRY_CONTRACT=0x_YOUR_DEPLOYED_ADDRESS
BLOBMASTER_WALLET_PRIVATE_KEY=0x_YOUR_PRIVATE_KEY

# ── x402 / Coinbase CDP ───────────────────────────────────────────────────────
CDP_API_KEY_ID=your_cdp_api_key_id
CDP_API_KEY_SECRET=your_cdp_api_key_secret
BLOBMASTER_WALLET_ADDRESS=0x_YOUR_RECEIVING_WALLET

# ── Vercel Cron Security ──────────────────────────────────────────────────────
# Generate: openssl rand -hex 32
CRON_SECRET=your_random_32_char_secret

# ── Database (Vercel Postgres) ────────────────────────────────────────────────
POSTGRES_PRISMA_URL=postgresql://...
POSTGRES_URL_NON_POOLING=postgresql://...

# ── Next.js ───────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://blobmaster.vercel.app

# ── Agent Vault /economy (uses blobmaster-sdk AgentVault + Walrus) ─────────────
# Uses BLOBMASTER_WALLET_PRIVATE_KEY
GEMINI_API_KEY=your_gemini_api_key
