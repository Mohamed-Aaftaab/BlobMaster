# ── Tatum (REQUIRED for hackathon judging) ────────────────────────────────────
# Get your free API key at https://dashboard.tatum.io
# Tatum provides the Sui RPC endpoints used by this project.
TATUM_API_KEY=your_tatum_api_key_here

# Tatum Sui RPC endpoint (powered by your API key above)
SUI_RPC_URL=https://sui-testnet.gateway.tatum.io

# ── BlobMaster Move Contract ───────────────────────────────────────────────────
# Live deployed package ID on Sui Testnet
# Explorer: https://testnet.suivision.xyz/package/0xa664fa704cf238fa6d87bc950bca4401c05ede372c42bd874eaefefe40dda2cf
BLOBMASTER_PACKAGE_ID=0xa664fa704cf238fa6d87bc950bca4401c05ede372c42bd874eaefefe40dda2cf

# ── Walrus ─────────────────────────────────────────────────────────────────────
WALRUS_AGGREGATOR_URL=https://aggregator.walrus-testnet.walrus.space
WALRUS_PUBLISHER_URL=https://publisher.walrus-testnet.walrus.space

# ── Keeper ─────────────────────────────────────────────────────────────────────
# The keeper is permissionless — ANYONE can run one and earn keeper rewards.
# Export your key with: sui keytool export --key-identity <address>
# NEVER used for user funds — keeper only calls execute_renewal() and earns rewards.
KEEPER_PRIVATE_KEY=suiprivkey...

# ── Vercel Cron Security ───────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Protects /api/keeper from unauthorized callers when deployed to Vercel.
CRON_SECRET=your_random_32_char_secret

# ── Next.js ────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://blobmaster-app.vercel.app
# ⚠️  Exposing your API key client-side means anyone can use your quota.
# For production, route RPC calls through a backend API endpoint instead.
NEXT_PUBLIC_TATUM_API_KEY=your_tatum_api_key_here

# ── Agent Economy demo (optional) ─────────────────────────────────────────────
# Used by the /economy simulation page. If not set, the guardian agent skips on-chain calls.
BLOBMASTER_WALLET_PRIVATE_KEY=suiprivkey...
BLOBMASTER_WALLET_ADDRESS=0x_your_receiving_wallet_address
