# ── Tatum (REQUIRED for hackathon judging) ────────────────────────────────────
# Get your free API key at https://dashboard.tatum.io
# Tatum provides the Sui RPC endpoints used by this project.
TATUM_API_KEY=your_tatum_api_key_here

# Tatum Sui RPC endpoints (powered by your API key above)
SUI_RPC_URL=https://sui-testnet.gateway.tatum.io

# ── BlobMaster Move Contract ───────────────────────────────────────────────────
# Deployed package ID on Sui Testnet
BLOBMASTER_PACKAGE_ID=0xf2c231a4ac2f95b6f88354a1a69b0e9e367bc728064b5ba14b5f8436b20f4a7e

# ── Walrus ─────────────────────────────────────────────────────────────────────
WALRUS_AGGREGATOR_URL=https://aggregator.walrus-testnet.walrus.space
WALRUS_PUBLISHER_URL=https://publisher.walrus-testnet.walrus.space

# ── Keeper (optional — only needed if running the server-side keeper) ──────────
# The keeper is a competition: ANYONE can run one and earn rewards.
# Get your suiprivkey from: sui keytool export --key-identity <address>
# NOTE: This is NEVER used for user funds. Keepers only call execute_renewal().
KEEPER_PRIVATE_KEY=suiprivkey...

# ── Vercel Cron Security ───────────────────────────────────────────────────────
# Generate: openssl rand -hex 32
# This protects the /api/keeper endpoint from unauthorized calls.
CRON_SECRET=your_random_32_char_secret

# ── Next.js ────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://blobmaster.vercel.app
NEXT_PUBLIC_TATUM_API_KEY=your_tatum_api_key_here

# ── AI features (optional) ─────────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key
